{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "UGPS API",
  "colors": {
    "primary": "#0F766E",
    "light": "#14B8A6",
    "dark": "#134E4A"
  },
  "favicon": "/favicon.svg",
  "openapi": "https://api.raul.ugps.io/api/openapi.json",
  "navigation": {
    "tabs": [
      {
        "tab": "Guía",
        "groups": [
          {
            "group": "Inicio",
            "pages": [
              "index",
              "api-reference/introduction"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "groups": [
          {
            "group": "Referencias",
            "pages": [
              "api-reference/introduction"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentación UGPS",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Health check",
        "href": "https://api.raul.ugps.io/api/health"
      }
    ],
    "primary": {
      "type": "button",
      "label": "OpenAPI JSON",
      "href": "https://api.raul.ugps.io/api/openapi.json"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ugps-2025/mintlify-docs"
    }
  }
}
